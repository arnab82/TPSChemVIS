# Auto-generated -- do not edit by hand. Edit driver_tpsci.jl.j2 instead.

using TPSChem
using TPSChem.QCBase
using TPSChem.RDM
using JLD2
using NPZ
using Printf

println("[driver_tpsci] loading CMF result from {{ cmf_result_path }}")
@load "{{ cmf_result_path }}" ints clusters init_fspace d1 e_cmf U

max_roots = {{ max_roots | default(20) }}
nroots    = {{ nroots | default(1) }}

println("[driver_tpsci] building cluster eigenbasis")
cluster_bases = TPSChem.compute_cluster_eigenbasis(ints, clusters;
                                                    verbose={{ verbose | default(1) }},
                                                    max_roots=max_roots,
                                                    init_fspace=init_fspace,
                                                    rdm1a=d1.a, rdm1b=d1.b)

clustered_ham = TPSChem.extract_ClusteredTerms(ints, clusters)
cluster_ops   = TPSChem.compute_cluster_ops(cluster_bases, ints)
TPSChem.add_cmf_operators!(cluster_ops, cluster_bases, ints, d1.a, d1.b)

ref_fock  = TPSChem.FockConfig(init_fspace)
ci_vector = TPSChem.TPSCIstate(clusters, ref_fock, R=nroots, T=Float64)

# --- seed configurations -------------------------------------------------
# Each assignment is `ci_vector[ref_fock][ClusterConfig(...)] = <length-nroots vector>`,
# following TPSChem.jl's own test/test_tpsci.jl pattern exactly.
# Ground state: every cluster in its own local ground state (index 1), root 1.
begin
    seed = zeros(Float64, nroots)
    seed[1] = 1.0
    ci_vector[ref_fock][TPSChem.ClusterConfig([1 for _ in clusters])] = seed
end

# EXCITED ROOTS (nroots > 1): add one single-exciton seed per extra root here,
# e.g. for root 2, promoting cluster 1 to its first local excited state:
#   begin
#       seed = zeros(Float64, nroots); seed[2] = 1.0
#       ci_vector[ref_fock][TPSChem.ClusterConfig([2,1,1,1])] = seed
#   end
# This is molecule/active-space specific (which cluster to excite, into
# which local state), so it is not auto-generated -- edit by hand or pass
# `extra_seeds` when rendering this template.
{% if extra_seeds is defined and extra_seeds %}
{% for seed in extra_seeds %}
begin
    seedvec = zeros(Float64, nroots); seedvec[{{ seed.root }}] = 1.0
    ci_vector[ref_fock][TPSChem.ClusterConfig({{ seed.config }})] = seedvec
end
{% endfor %}
{% endif %}

println("[driver_tpsci] running TPSCI")
e0, v0 = TPSChem.tpsci_ci(ci_vector, cluster_ops, clustered_ham;
                           incremental=true,
                           ci_conv={{ ci_conv | default("1e-8") }},
                           thresh_cipsi={{ thresh_cipsi | default("1e-3") }},
                           thresh_foi={{ thresh_foi | default("1e-6") }},
                           thresh_asci={{ thresh_asci | default("-1") }},
                           conv_thresh={{ conv_thresh | default("1e-7") }})

e2 = TPSChem.compute_pt2_energy(v0, cluster_ops, clustered_ham;
                                 thresh_foi={{ pt2_thresh_foi | default("1e-8") }})

@printf("[driver_tpsci] E(TPSCI)     = %s\n", string(e0))
@printf("[driver_tpsci] E(TPSCI+PT2) = %s\n", string(e0 .+ e2))

mkpath("{{ output_dir }}")
jldsave("{{ output_dir }}/tpsci_result.jld2"; e0=e0, e2=e2, v0=v0)
open("{{ output_dir }}/energies.txt", "w") do io
    println(io, "E(TPSCI): ", e0)
    println(io, "E(TPSCI+PT2): ", e0 .+ e2)
end

println("[driver_tpsci] done")
