#!/bin/bash
{#
  Auto-generated by Active Space Builder. Adjust account/partition/time
  for your actual supercomputer allocation before submitting -- these are
  placeholders pulled from the export dialog.
#}
#SBATCH --job-name={{ job_name | default('tpsci_job') }}
#SBATCH --account={{ account }}
#SBATCH --partition={{ partition | default('normal') }}
#SBATCH --nodes={{ nodes | default(1) }}
#SBATCH --ntasks-per-node={{ ntasks_per_node | default(1) }}
#SBATCH --cpus-per-task={{ cpus_per_task | default(16) }}
#SBATCH --mem={{ mem | default('64G') }}
#SBATCH --time={{ walltime | default('24:00:00') }}
#SBATCH --output={{ job_name | default('tpsci_job') }}.%j.out
#SBATCH --error={{ job_name | default('tpsci_job') }}.%j.err

set -euo pipefail

# Pin the exact Julia version this project was built/tested against.
{% if use_juliaup %}
JULIA_BIN="$(juliaup which {{ julia_version | default('1.11') }})"
{% else %}
module load julia/{{ julia_version | default('1.11') }}
JULIA_BIN="julia"
{% endif %}

"$JULIA_BIN" --version
"$JULIA_BIN" --project="{{ julia_project }}" -t{{ threads | default('auto') }} "{{ driver_script }}"
