{#
  Auto-generated by Active Space Builder. Runs Cluster Mean-Field (CMF)
  orbital optimization via TPSChem.jl, starting from integrals written by
  the Python side as h0/h1/h2.npy (InCoreInts contract, no PyCall needed).

  Supports two CMF backends selected by the GUI:
    use_newton=true  -> cmf_oo_newton (per-cluster FCIAnsatz, Newton solver)
    use_newton=false -> cmf_oo        (BFGS or DIIS method=)

  Pattern verified against:
    - TPSChem.jl test/test_direct_cmf.jl
    - examples/notes/cmf.jl (cmf_oo_newton with FCIAnsatz)
#}
# Auto-generated -- do not edit by hand. Edit driver_cmf.jl.j2 instead.

using PyCall          # must load before TPSChem to activate TPSChemPyCallExt
using TPSChem
using TPSChem.QCBase
using TPSChem.InCoreIntegrals
using TPSChem.RDM
using TPSChem.ClusterMeanField
using TPSChem.ActiveSpaceSolvers: FCIAnsatz
using NPZ
using JLD2
using Printf

println("[driver_cmf] loading integrals from {{ h0_path }}")
h0 = npzread("{{ h0_path }}")
h1 = npzread("{{ h1_path }}")
h2 = npzread("{{ h2_path }}")
ints = InCoreInts(h0, h1, h2)

clusters    = {{ clusters_literal }}
init_fspace = {{ init_fspace_literal }}

d1 = RDM1(n_orb(ints))

{% if use_newton %}
ansatze = {{ ansatze_literal }}

println("[driver_cmf] running cmf_oo_newton (Newton solver)")
e_cmf, U, d1 = ClusterMeanField.cmf_oo_newton(ints, clusters, init_fspace, ansatze, d1;
                    maxiter_oo      = {{ max_iter_oo | default(400) }},
                    tol_oo          = {{ tol_oo | default("1e-8") }},
                    tol_d1          = {{ tol_d1 | default("1e-9") }},
                    tol_ci          = {{ tol_ci | default("1e-11") }},
                    verbose         = {{ verbose | default(4) }},
                    zero_intra_rots = {{ zero_intra_rots | default("false") }},
                    sequential      = {{ sequential | default("true") }})
{% else %}
println("[driver_cmf] running cmf_oo (method={{ method | default('bfgs') }})")
e_cmf, U, d1 = cmf_oo(ints, clusters, init_fspace, d1;
                    max_iter_oo = {{ max_iter_oo | default(60) }},
                    gconv       = {{ gconv | default("1e-10") }},
                    method      = "{{ method | default('bfgs') }}",
                    verbose     = {{ verbose | default(1) }})
{% endif %}

@printf("[driver_cmf] E(CMF) = %.10f Ha\n", e_cmf)

ints_rot = orbital_rotation(ints, U)

mkpath("{{ output_dir }}")

# JLD2 bundle: handed off to driver_tpsci.jl / driver_spt.jl.
jldsave("{{ output_dir }}/cmf_result.jld2";
        ints=ints_rot, clusters=clusters, init_fspace=init_fspace,
        d1=d1, e_cmf=e_cmf, U=U)

# Plain files for the Python GUI to read without a Julia/JLD2 reader.
npzwrite("{{ output_dir }}/h1_cmf.npy", ints_rot.h1)
npzwrite("{{ output_dir }}/h2_cmf.npy", ints_rot.h2)
open("{{ output_dir }}/e_cmf.txt", "w") do io
    println(io, e_cmf)
end

println("[driver_cmf] done")
